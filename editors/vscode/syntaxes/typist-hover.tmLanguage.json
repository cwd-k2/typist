{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Typist",
  "scopeName": "source.typist",
  "patterns": [
    { "include": "#sub-declaration" },
    { "include": "#type-declaration" },
    { "include": "#generics-block" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#variables" },
    { "include": "#effect-marker" },
    { "include": "#arrow" },
    { "include": "#unicode-arrow" },
    { "include": "#fat-comma" },
    { "include": "#variadic" },
    { "include": "#field-name" },
    { "include": "#method-call" },
    { "include": "#wildcard" },
    { "include": "#operators" },
    { "include": "#primitive-types" },
    { "include": "#builtin-types" },
    { "include": "#type-variables" },
    { "include": "#type-names" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "sub-declaration": {
      "match": "\\b(sub)\\s+([a-z_]\\w*)",
      "captures": {
        "1": { "name": "keyword.control.typist" },
        "2": { "name": "entity.name.function.typist" }
      }
    },
    "type-declaration": {
      "match": "\\b(type|struct|effect|typeclass|datatype|newtype)\\s+([A-Z]\\w*)",
      "captures": {
        "1": { "name": "keyword.control.typist" },
        "2": { "name": "entity.name.type.typist" }
      }
    },
    "generics-block": {
      "begin": "(?<=\\w)<",
      "end": ">",
      "beginCaptures": { "0": { "name": "punctuation.angle.typist" } },
      "endCaptures": { "0": { "name": "punctuation.angle.typist" } },
      "patterns": [
        {
          "comment": "Type parameter with bound (e.g. T: Num, r: Row)",
          "match": "\\b([a-zA-Z_]\\w*)\\s*(:)(?!:)",
          "captures": {
            "1": { "name": "variable.parameter.typist" },
            "2": { "name": "punctuation.colon.typist" }
          }
        },
        { "include": "#arrow" },
        { "include": "#unicode-arrow" },
        { "include": "#operators" },
        { "include": "#primitive-types" },
        { "include": "#builtin-types" },
        { "include": "#type-names" },
        {
          "comment": "Unbounded type parameter (e.g. T, r, _)",
          "match": "\\b[a-zA-Z_]\\w*\\b",
          "name": "variable.parameter.typist"
        },
        { "include": "#punctuation" }
      ]
    },
    "strings": {
      "match": "'[^']*'",
      "name": "string.quoted.single.typist"
    },
    "numbers": {
      "match": "\\b\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.typist"
    },
    "variables": {
      "match": "[$@%]\\w+",
      "name": "variable.other.typist"
    },
    "effect-marker": {
      "match": "!(?=\\s*\\[|\\s*[A-Z])",
      "name": "keyword.operator.effect.typist"
    },
    "arrow": {
      "match": "->",
      "name": "keyword.operator.arrow.typist"
    },
    "unicode-arrow": {
      "match": "\u2192",
      "name": "keyword.operator.arrow.typist"
    },
    "fat-comma": {
      "match": "=>",
      "name": "keyword.operator.fat-comma.typist"
    },
    "variadic": {
      "match": "\\.\\.\\.",
      "name": "keyword.operator.variadic.typist"
    },
    "field-name": {
      "match": "\\b([a-z_]\\w*)(\\?)?(?=\\s*:(?!:))",
      "captures": {
        "1": { "name": "variable.other.member.typist" },
        "2": { "name": "keyword.operator.optional.typist" }
      }
    },
    "method-call": {
      "match": "\\b([a-z_]\\w*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "entity.name.function.typist" }
      }
    },
    "wildcard": {
      "match": "\\*",
      "name": "keyword.operator.wildcard.typist"
    },
    "operators": {
      "match": "[|&=+]",
      "name": "keyword.operator.typist"
    },
    "primitive-types": {
      "match": "\\b(Int|Str|Bool|Void|Any|Never|Undef|Num|Double)\\b",
      "name": "support.type.primitive.typist"
    },
    "builtin-types": {
      "match": "\\b(Array|ArrayRef|Hash|HashRef|Maybe|Record|Tuple|Ref|Literal)\\b",
      "name": "support.type.typist"
    },
    "type-variables": {
      "match": "\\b[A-Za-z]\\b",
      "name": "variable.parameter.typist"
    },
    "type-names": {
      "match": "\\b[A-Z]\\w+\\b",
      "name": "entity.name.type.typist"
    },
    "punctuation": {
      "patterns": [
        { "match": "[()]", "name": "punctuation.paren.typist" },
        { "match": "[\\[\\]]", "name": "punctuation.bracket.typist" },
        { "match": "[<>]", "name": "punctuation.angle.typist" },
        { "match": "[{}]", "name": "punctuation.brace.typist" },
        { "match": ",", "name": "punctuation.comma.typist" },
        { "match": ";", "name": "punctuation.semicolon.typist" },
        { "match": ":(?!:)", "name": "punctuation.colon.typist" }
      ]
    }
  }
}
